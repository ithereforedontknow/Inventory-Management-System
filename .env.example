# ============================================================
# StockPilot — Environment Configuration
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# ============================================================

# --- Database ---
DB_HOST=db
DB_PORT=3306
DB_NAME=inventory_db
DB_USER=inventory_user
DB_PASS=change_me_strong_password

MYSQL_ROOT_PASSWORD=change_me_root_password
MYSQL_DATABASE=inventory_db
MYSQL_USER=inventory_user
MYSQL_PASSWORD=change_me_strong_password

# --- Auth (JWT) ---
# Generate with: openssl rand -hex 64
JWT_SECRET=change_me_generate_a_64_char_hex_secret_using_openssl_rand_hex_64
JWT_EXPIRY_HOURS=8

# --- App ---
APP_ENV=local
APP_NAME=StockPilot

# --- CORS ---
# Comma-separated list of allowed origins. For local use: http://localhost:3000
ALLOWED_ORIGINS=http://localhost:3000
-e 
# Default admin password (used only on first boot to seed the admin user)
ADMIN_PASSWORD=Admin1234
